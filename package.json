{
  "name": "labor.fun",
  "version": "0.1.0",
  "description": "labor.fun — a standalone, multi-org framework for multi-channel AI assistants. Runs Claude agents in isolated containers with per-group memory; each organization is a drop-in profile.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "sync-discord-members": "tsx scripts/sync-discord-members.ts",
    "sync-slack-members": "tsx scripts/sync-slack-members.ts",
    "pm-preview": "tsx scripts/pm-preview.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@onecli-sh/sdk": "^0.2.0",
    "@safe-global/api-kit": "^5.0.1",
    "@safe-global/protocol-kit": "^8.0.1",
    "@slack/bolt": "^4.3.0",
    "@slack/types": "^2.15.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "discord.js": "^14.18.0",
    "ethers": "^6.17.0",
    "express-basic-auth": "^1.2.1",
    "grammy": "^1.39.3",
    "gray-matter": "^4.0.3",
    "imapflow": "^1.3.1",
    "marked": "^18.0.0",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/imapflow": "^1.0.23",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "staticrypt": "^3.5.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
