# labor.fun — TEE deployment mode environment (dstack / Phala Intel-TDX CVM)
# ---------------------------------------------------------------------------
# Copy to `.env.tee` and fill in. This file is passed to the dstack/phala CLI
# at deploy time; dstack stores it as an ENCRYPTED environment provisioned to
# the CVM AFTER attestation validates (secrets never touch the compose_hash).
# See deploy/tee/README.md and docs/TEE.md ("secret model").
#
# NEVER commit a filled-in .env.tee. Only this .example is tracked.
# ---------------------------------------------------------------------------

# --- Org profile ------------------------------------------------------------
# Which profiles/<name>/ the orchestrator activates. Must match a profile whose
# state is present on the encrypted `labor-profiles` volume.
LABOR_PROFILE=vinny

# --- Images (PIN BY DIGEST) -------------------------------------------------
# The orchestrator image is pinned in docker-compose.tee.yaml (measured into
# compose_hash). The AGENT image spawned per turn is referenced here; pin it by
# @sha256 digest and record the digest in docs/TEE.md so it can be verified
# out-of-band (its digest is NOT part of compose_hash — see the compose header).
AGENT_IMAGE=ghcr.io/breadchaincoop/labor-agent@sha256:REPLACE_WITH_AGENT_DIGEST

# --- Signal -----------------------------------------------------------------
# The shared platform Signal number (E.164). The TEE links to it as a SECONDARY
# DEVICE; the CP gateway holds the PRIMARY. Each side only acts on ITS orgs'
# groups (docs/TEE.md → "split-brain rule").
SIGNAL_ACCOUNT=+15555550123

# --- Inference: NEAR AI (owned by the parallel inference-mode work) ---------
# Referenced here so orchestrator + agent turns route inference to NEAR AI
# instead of api.anthropic.com. No inference container runs in the CVM.
INFERENCE_BACKEND=near-ai
NEAR_AI_API_KEY=REPLACE_WITH_NEAR_AI_KEY
NEAR_AI_MODEL=deepseek-ai/DeepSeek-V3.1

# --- TEE / attestation ------------------------------------------------------
# TEE_MODE=true flips on the `!verify` attestation reply in the Signal channel.
# The code still checks the dstack socket exists before attesting, so leaving
# this true outside a CVM degrades honestly ("not running in a TEE").
TEE_MODE=true
DSTACK_SOCKET_PATH=/var/run/dstack.sock
# Public quote verifier linked in !verify replies.
TEE_VERIFY_URL=https://proof.phala.network

# --- Misc -------------------------------------------------------------------
TZ=UTC
LOG_LEVEL=info
