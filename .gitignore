# Dependencies
node_modules/
.npm-cache/

# Build output
dist/

# Org profiles are LOCAL instances — never tracked in the shared framework repo.
# Only the `example` template is committed. Each org (breadchain, acme, …) is
# created locally from profiles/example and lives only on that org's clone/host
# (config, deploy.config, deploy.env, KB, plugins, store, data — all local).
/profiles/*
!/profiles/example/

# Legacy root layout (pre-profile dev installs)
store/
data/
.config/
logs/

# Secrets
*.keys.json
.env
kb-ui/users.json

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Local state
.nanoclaw/
agents-sdk-docs

# Staging
staging-data/
.env.staging
.env.staging.local
.claude-backups/

# Legacy root-layout KB content (pre-profile dev installs).
groups/*/context/

# Runtime lock file written by the schedule skill — never commit
.claude/scheduled_tasks.lock
