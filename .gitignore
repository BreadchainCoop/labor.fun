# Dependencies
node_modules/
.npm-cache/

# Build output
dist/

# Local data & runtime (per-profile and legacy root layout)
store/
data/
profiles/*/store/
profiles/*/data/
# Local-only staging profile (created by scripts/staging.sh)
profiles/staging/
.config/
logs/

# Secrets
*.keys.json
.env
kb-ui/users.json

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Local state
.nanoclaw/
agents-sdk-docs

# Staging
staging-data/
.env.staging
.env.staging.local
.claude-backups/

# Live-edited KB content for the breadchain profile lives on the droplet and is
# preserved as stateful by safe-deploy.sh — keep it gitignored to avoid drift.
# (The example profile's context/ IS tracked as a template; other orgs can
# choose to track or ignore their own profile's context the same way.)
profiles/breadchain/groups/*/context/
groups/*/context/

# Runtime lock file written by the schedule skill — never commit
.claude/scheduled_tasks.lock
