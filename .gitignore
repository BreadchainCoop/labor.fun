# Live-edited KB content lives on the droplet under /opt/breadbrich/groups/*/context/
# and is preserved as stateful by safe-deploy.sh — the repo cannot be the source
# of truth without a real sync mechanism. Keep this gitignored to avoid drift;
# add new entries via the live system (or scp) rather than via PR.
# See project_breadbrich_kb_mount_gap.md memory for the full rationale.
groups/*/context/

# Runtime lock file written by the schedule skill — never commit
.claude/scheduled_tasks.lock
