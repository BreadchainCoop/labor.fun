# Infra config for THIS org's deployment. Sourced by the deploy shell scripts
# (NOT loaded by the app). Copy this profile, then set these to your own host's
# install paths, systemd service names, OS user, and framework repo URL.
#
# Everything an org owns about its infrastructure lives here — pick your own
# values; nothing is shared with other orgs on other hosts.
DEPLOY_ROOT=/opt/labor.fun
GIT_DIR=/opt/labor.fun-git
BACKUP_DIR=/opt/labor.fun-backups
SERVICE_NAME=laborfun
KB_SERVICE_NAME=laborfun-kb
AUTO_DEPLOY_NAME=laborfun-auto-deploy
SERVICE_USER=laborfun
REPO_URL=https://github.com/your-org/labor.fun.git
# Runtime env (NODE_ENV, KB_PORT, KB_ADMINS, …) is read from this profile's
# deploy.env automatically; set DEPLOY_ENV_FILE only for a non-standard path.
