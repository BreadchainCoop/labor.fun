# Runtime config loaded by systemd (orchestrator + KB dashboard). Non-secret;
# secrets live in the host's .env (loaded by readEnvFile inside Node).
# Referenced by deploy.config's DEPLOY_ENV_FILE. Copy + edit per org.

NODE_ENV=production

# Selects the active profile. Must match this profile's directory name.
LABOR_PROFILE=example

# Host address agent containers reach the credential proxy on (Docker bridge gw).
CREDENTIAL_PROXY_HOST=172.17.0.1

# KB dashboard. CONTEXT_DIR / DB_PATH are derived from the profile automatically,
# so you usually only set the port here.
KB_PORT=8080
# Access is flat (an allowlisted user has full access). KB_SUPERADMINS is the one
# remaining gate — it restricts the /admin credentials page, which exposes
# secrets — so set it to your real superadmin username(s). KB_ADMINS (and the
# legacy KB_COORDINATORS / KB_RESIDENTS the dashboard still reads) are slated to
# be flattened away; leave KB_ADMINS matching KB_SUPERADMINS for now.
KB_SUPERADMINS=admin
KB_ADMINS=admin
