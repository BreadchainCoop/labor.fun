# Infra config for the breadchain deployment. Sourced by the deploy shell
# scripts (NOT loaded by the app). Per-org host identity: install paths,
# systemd service names, OS user, and the framework repo to pull from.
# These values reproduce breadchain's existing droplet exactly.
DEPLOY_ROOT=/opt/breadbrich
GIT_DIR=/opt/breadbrich-git
BACKUP_DIR=/opt/breadbrich-backups
SERVICE_NAME=breadbrich
KB_SERVICE_NAME=breadbrich-kb
AUTO_DEPLOY_NAME=breadbrich-auto-deploy
SERVICE_USER=breadbrich
REPO_URL=https://github.com/BreadchainCoop/labor.fun.git
# Runtime env file loaded by systemd (NODE_ENV, KB_PORT, KB_ADMINS, LABOR_PROFILE…).
DEPLOY_ENV_FILE=/opt/breadbrich/setup/breadbrich-deploy.env
