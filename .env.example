# Active org profile. Selects which profiles/<name>/ directory holds this
# install's identity, KB, groups, and runtime state (store/, data/). Optional
# when exactly one non-example profile exists (it's auto-selected); required
# when several are present. See src/profile.ts and docs/NEW-ORG-GUIDE.md.
LABOR_PROFILE=breadchain

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Discord bot token from the Discord Developer Portal (Bot tab).
# Enables the Discord channel; auto-detected when present.
DISCORD_BOT_TOKEN=

# Email whitelist — comma-separated list of allowed inbound/outbound email addresses.
# Required; if unset, all email send/receive is rejected.
EMAIL_WHITELIST=user1@example.com,user2@example.com

# KB-UI role membership — comma-separated lowercase usernames.
# KB_ADMINS is required for any admin access; others are optional.
KB_ADMINS=admin1,admin2
KB_SUPERADMINS=admin1
KB_COORDINATORS=coord1
KB_RESIDENTS=resident1,resident2

# KB-UI channel-name display map — JSON object mapping JID -> display name.
# Used for the channels stats panel; if unset, raw JIDs are shown.
KB_CHANNEL_NAMES={"slack:CXXXXXXXX":"Slack #main","tg:1234567890":"TG: User"}

# Telegram bot username (without the @) — used in UI displays and registration prompts.
TELEGRAM_BOT_USERNAME=your_bot_username

# Droplet SSH target — used by scripts/deploy.sh, scripts/smoke-test.sh,
# scripts/pull-backups.sh, scripts/setup-droplet-gitpull.sh, and the kb-ui
# architecture diagram. Format: user@host or user@ip.
DROPLET_HOST=root@your-droplet.example.com

# Droplet display label — shown in the kb-ui architecture diagram.
# Optional; if unset, falls back to a generic "configured droplet" label.
BREADBRICH_DROPLET_LABEL=breadbrich-droplet

# Slack channel JID that whitelisted inbound emails get forwarded to.
# Required for the email→Slack relay; if unset, the relay is disabled.
EMAIL_FORWARD_SLACK_CHANNEL=slack:CXXXXXXXXX

# Smoke-test expected registered JIDs — comma-separated list of group JIDs that
# scripts/smoke-test.sh asserts are registered in the running orchestrator.
# Optional; if unset, the per-JID assertions are skipped (count check still runs).
EXPECTED_REGISTERED_JIDS=slack:CXXXXXXXXX,slack:CYYYYYYYY,tg:NNNNNNNN

# Identity seed for the user_identities table — JSON array of platform_id /
# platform / kb_person entries. Run on every startup but idempotent (INSERT OR
# IGNORE), so existing rows are preserved. Used to bootstrap a fresh DB so
# admins are recognized before the first inbound message from each platform.
# If unset, no identities are seeded.
SEED_IDENTITIES=[{"platform_id":"cli:admin","platform":"cli","kb_person":"admin"}]

# Shared KB source group — which group's context/ is mounted at
# /workspace/shared-kb (read-only) for every group container. This is how
# non-main groups (e.g. telegram_<user>) resolve people/calendar/task lookups
# that live in the canonical KB location. Default: slack_main.
SHARED_KB_GROUP=slack_main

# Cooperative mode (flat access). When enabled (default), EVERY registered
# group is treated as a privileged "main" group: read-write SQLite store
# mount and full IPC authorization (including KB writes) in every container,
# with no main/non-main distinction. This intentionally removes the
# prompt-injection trust boundary — every channel can read and mutate
# org-wide data and the RBAC tables — so it is ONLY safe when every channel
# is trusted-internal (no public/visitor-facing channels). Set to false to
# restore the sandboxed main/non-main model. See docs/COOPERATIVE-MODE.md.
FLAT_ACCESS=true

# --- Discord DM role-based allowlist (optional) ---
# When set, the bot auto-registers a DM as its own group the first time it
# receives a message from a user who holds any of these Discord role IDs in
# a shared guild. Auto-registered DMs run with requires_trigger=0 (no @mention
# needed). Background refresh re-checks roles every
# DISCORD_DM_ROLE_REFRESH_INTERVAL ms and deregisters on revocation (folder +
# data preserved). Leave empty to keep the strict "explicit registration only"
# model.
DISCORD_DM_ALLOWED_ROLE_IDS=
# Optional: restrict role lookup to specific guild IDs. Empty = every guild
# the bot is in.
DISCORD_DM_ALLOWED_GUILD_IDS=
# Default 600000 (10 min). Set to 0 to disable refresh (allowlist sticky).
DISCORD_DM_ROLE_REFRESH_INTERVAL=600000

# How often the Discord-members → KB people sync re-runs in the background
# alongside the orchestrator. Default 1 hour. Set to 0 to disable the
# periodic loop; the one-shot `npm run sync-discord-members` still works.
DISCORD_MEMBERS_SYNC_INTERVAL_MS=3600000

# --- GitHub Projects V2 → KB sync ---
# Comma-separated GitHub org slugs whose ProjectsV2 boards (and their items)
# should be mirrored into the KB. Empty = feature off. Each org's projects
# land as `context/projects/GHP-<org>-<n>.md`; each project item lands as
# `context/tasks/GH-<org>-<repo>-<issue#>.md` (or `GHD-...` for draft items).
# The existing /projects kb-ui page reads them alongside hand-authored
# TASK-NNN / PROJECT-* files (Option A — single unified namespace).
#
# Requires GITHUB_PERSONAL_ACCESS_TOKEN to have `read:project` (fine-grained:
# "Projects: Read") on each org.
GITHUB_PROJECT_SYNC_ORGS=
# Sync interval in milliseconds. Default 15 minutes. Set to 0 to disable.
GITHUB_PROJECT_SYNC_INTERVAL_MS=900000
# Comma-separated case-insensitive substrings. Any project whose title
# contains one of these is skipped at sync time (and so are its items).
# Empty titles are always skipped. Default catches GitHub's auto-named
# "@<user>'s untitled project" boards plus categorization boards named
# "Breadchain Micro" / "Breadchain Macro". Set to "," to disable.
GITHUB_PROJECT_HIDE_TITLE_PATTERNS=untitled,micro,macro
# Pull GitHub issue dependency (blocked-by/blocking) + sub-issue (parent/child)
# edges into synced task frontmatter as upstream/downstream, so the PM
# orchestrator sees a real dependency graph (#31). Default on; the sync degrades
# gracefully (retries without edges) on instances that lack the GraphQL fields.
GITHUB_SYNC_ISSUE_DEPS=true

# --- Escalating-deadline reminder engine (#25) ---
# Sweeps KB tasks with a `deadline:` and posts reminders on a tightening ladder
# as the deadline approaches, looping in an escalation contact at the final tick
# / when overdue. Disabled when the ladder is empty or the interval is 0.
#
# Ladder: comma-separated offsets-before-deadline (w/d/h/m). Closest rung is the
# "final tick" escalation. Default T-3w → T-1w → T-3d → T-1d.
REMINDER_LADDER=3w,1w,3d,1d
# How often the sweep runs (ms). Rungs are day-scale, so 1h is plenty. 0 = off.
REMINDER_SWEEP_INTERVAL_MS=3600000
# Where reminders are delivered. Empty = the shared-KB group's chat (the channel
# the team already watches). Override with a specific slack:/dc:/tg: JID.
REMINDER_TARGET_JID=
# Org-wide fallback escalation contact for tasks that don't set their own
# `escalation_contact`. Empty = no default (final-tick reminders just name owners).
REMINDER_ESCALATION_CONTACT=

# --- PM orchestration (#31) ---
# Periodic loop that reviews the GitHub-synced + hand-authored task graph and
# wakes the agent to re-estimate/re-plan and DM blockers/overdue owners (the
# agent acts optimistically, then asks the human to confirm). Disabled when the
# interval is 0. Weekly by default. Needs GITHUB_SYNC_ISSUE_DEPS (above) for the
# dependency graph on synced issues; degrades to overdue/load-only without edges.
PM_ORCHESTRATION_INTERVAL_MS=604800000
# Group whose chat receives the PM run. Empty → the shared-KB group.
PM_ORCHESTRATION_TARGET_GROUP=
# A task is flagged "due soon" within this many days of its deadline.
PM_DUE_SOON_DAYS=7
# Don't re-DM the same person about the same task+reason within this window (ms).
# Default ~6 days, shorter than the weekly cadence so persistent issues re-raise.
PM_DM_COOLDOWN_MS=518400000
# Fallback contact for overdue/blocking work that has NO assignee — the agent
# raises unowned items to this person (and the channel) instead of dropping
# them. Empty = post unowned items to the channel only. The routine can also be
# triggered on demand from chat: "@<bot> run pm orchestration" or "/pm".
PM_LEAD=

# --- Operational reports (#34) ---
# Recurring leadership readout of operational state: what's late (by team and by
# person), per-member load vs. declared capacity (with a soft over-capacity
# flag), and a bottleneck digest from the PM layer. Deterministic — it never
# wakes the agent, so it costs no API spend. Disabled when the interval is 0.
# Reads member capacity from people-profile frontmatter (expected_hours_per_week,
# capacity_points, team, pay_parity_note — all optional, self-declared).
# The loop SWEEPS on this interval (default daily) but POSTS at most once per
# period (see OPS_REPORT_PERIOD); a rolling copy is always written to
# context/operational-report.md. 0 disables.
OPS_REPORT_INTERVAL_MS=86400000
# Group whose chat receives the report. Empty → the shared-KB group. Point this
# at a private leadership channel when OPS_REPORT_AUDIENCE=leaders.
OPS_REPORT_TARGET_GROUP=
# 'leaders' → full per-person hours/load detail (private channel; default).
# 'coop'    → team-level aggregates only, no per-person hours, gentler framing.
OPS_REPORT_AUDIENCE=leaders
# Post cadence / idempotency bucket: 'weekly' (ISO week; default) or 'monthly'.
OPS_REPORT_PERIOD=weekly
# A task counts as "due soon" within this many days of its deadline.
OPS_REPORT_DUE_SOON_DAYS=7
# Soft-flag a member as over capacity when open estimate / declared capacity
# exceeds this ratio (float). Default 1.0 = any over-capacity. Only ever applied
# to members who actually declared a capacity_points — never fabricated.
OPS_REPORT_OVERLOAD_RATIO=1.0

# Service email account — IMAP poller checks this mailbox for whitelisted
# senders and routes them as inbound messages. Both must be set for the
# poller to start; otherwise it logs a warning and stays idle.
BREADBRICH_EMAIL=breadbrich@your-domain.example
BREADBRICH_EMAIL_PASSWORD=your-google-workspace-app-password

# Slack bot username — shown on the kb-ui /admin credentials table.
# Optional; falls back to "breadbrich" if unset.
SLACK_BOT_USERNAME=your-bot-username

# Google Workspace credentials file for the bundled `gws` MCP server
# (Gmail, Calendar, Drive, Docs, Sheets, Tasks). Generate on the host with:
#   npm install -g @googleworkspace/cli
#   gws auth setup
#   gws auth login -s drive,gmail,calendar,sheets,docs,tasks
#   gws auth export --unmasked > ~/.config/gws/credentials.json
# Path is mounted read-only into the container; auto-detected when set,
# server not loaded when absent.
GOOGLE_WORKSPACE_CREDENTIALS_FILE=/absolute/path/to/gws-credentials.json

# Breadbrich's GitHub fine-grained PAT (his own account), authorized for the
# BreadchainCoop org with Contents/Issues/Pull requests RW + Actions/Metadata
# read. Enables the bundled github-mcp-server (mcp__github__*); auto-detected
# when present, server not loaded when absent. See rules/integrations/github.md.
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...

# Inbound GitHub @-mentions (off by default). When enabled, the bot polls its
# own GitHub notifications and responds in-thread when tagged — but ONLY to
# mentions from members of the configured org (githubOrg). The PAT above also
# needs Notifications access + read:org, and should belong to a dedicated bot
# account (the notifications API reports mentions of the authenticated user).
# See rules/integrations/github.md.
GITHUB_MENTIONS_ENABLED=false
# Optional: pin the bot's GitHub handle (else resolved via GET /user on start).
GITHUB_BOT_LOGIN=

# Linear personal API key (Settings → Account → Security & access). Enables the
# remote Linear MCP server (mcp__linear__*) at https://mcp.linear.app/mcp;
# passed as a Bearer token. Auto-detected when present, server not loaded when
# absent. Workspace/team scope is determined by the key. See
# rules/integrations/linear.md.
LINEAR_API_KEY=lin_api_...
