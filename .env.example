SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Discord bot token from the Discord Developer Portal (Bot tab).
# Enables the Discord channel; auto-detected when present.
DISCORD_BOT_TOKEN=

# Email whitelist — comma-separated list of allowed inbound/outbound email addresses.
# Required; if unset, all email send/receive is rejected.
EMAIL_WHITELIST=user1@example.com,user2@example.com

# KB-UI role membership — comma-separated lowercase usernames.
# KB_ADMINS is required for any admin access; others are optional.
KB_ADMINS=admin1,admin2
KB_SUPERADMINS=admin1
KB_COORDINATORS=coord1
KB_RESIDENTS=resident1,resident2

# KB-UI channel-name display map — JSON object mapping JID -> display name.
# Used for the channels stats panel; if unset, raw JIDs are shown.
KB_CHANNEL_NAMES={"slack:CXXXXXXXX":"Slack #main","tg:1234567890":"TG: User"}

# Telegram bot username (without the @) — used in UI displays and registration prompts.
TELEGRAM_BOT_USERNAME=your_bot_username

# Droplet SSH target — used by scripts/deploy.sh, scripts/smoke-test.sh,
# scripts/pull-backups.sh, scripts/setup-droplet-gitpull.sh, and the kb-ui
# architecture diagram. Format: user@host or user@ip.
DROPLET_HOST=root@your-droplet.example.com

# Droplet display label — shown in the kb-ui architecture diagram.
# Optional; if unset, falls back to a generic "configured droplet" label.
BREADBRICH_DROPLET_LABEL=breadbrich-droplet

# Slack channel JID that whitelisted inbound emails get forwarded to.
# Required for the email→Slack relay; if unset, the relay is disabled.
EMAIL_FORWARD_SLACK_CHANNEL=slack:CXXXXXXXXX

# Smoke-test expected registered JIDs — comma-separated list of group JIDs that
# scripts/smoke-test.sh asserts are registered in the running orchestrator.
# Optional; if unset, the per-JID assertions are skipped (count check still runs).
EXPECTED_REGISTERED_JIDS=slack:CXXXXXXXXX,slack:CYYYYYYYY,tg:NNNNNNNN

# Identity seed for the user_identities table — JSON array of platform_id /
# platform / kb_person entries. Run on every startup but idempotent (INSERT OR
# IGNORE), so existing rows are preserved. Used to bootstrap a fresh DB so
# admins are recognized before the first inbound message from each platform.
# If unset, no identities are seeded.
SEED_IDENTITIES=[{"platform_id":"cli:admin","platform":"cli","kb_person":"admin"}]

# Shared KB source group — which group's context/ is mounted at
# /workspace/shared-kb (read-only) for every group container. This is how
# non-main groups (e.g. telegram_<user>) resolve people/calendar/task lookups
# that live in the canonical KB location. Default: slack_main.
SHARED_KB_GROUP=slack_main

# Cooperative mode (flat access). When enabled (default), EVERY registered
# group is treated as a privileged "main" group: read-write SQLite store
# mount and full IPC authorization (including KB writes) in every container,
# with no main/non-main distinction. This intentionally removes the
# prompt-injection trust boundary — every channel can read and mutate
# org-wide data and the RBAC tables — so it is ONLY safe when every channel
# is trusted-internal (no public/visitor-facing channels). Set to false to
# restore the sandboxed main/non-main model. See docs/COOPERATIVE-MODE.md.
FLAT_ACCESS=true

# --- Discord DM role-based allowlist (optional) ---
# When set, the bot auto-registers a DM as its own group the first time it
# receives a message from a user who holds any of these Discord role IDs in
# a shared guild. Auto-registered DMs run with requires_trigger=0 (no @mention
# needed). Background refresh re-checks roles every
# DISCORD_DM_ROLE_REFRESH_INTERVAL ms and deregisters on revocation (folder +
# data preserved). Leave empty to keep the strict "explicit registration only"
# model.
DISCORD_DM_ALLOWED_ROLE_IDS=
# Optional: restrict role lookup to specific guild IDs. Empty = every guild
# the bot is in.
DISCORD_DM_ALLOWED_GUILD_IDS=
# Default 600000 (10 min). Set to 0 to disable refresh (allowlist sticky).
DISCORD_DM_ROLE_REFRESH_INTERVAL=600000

# --- GitHub Projects V2 → KB sync ---
# Comma-separated GitHub org slugs whose ProjectsV2 boards (and their items)
# should be mirrored into the KB. Empty = feature off. Each org's projects
# land as `context/projects/GHP-<org>-<n>.md`; each project item lands as
# `context/tasks/GH-<org>-<repo>-<issue#>.md` (or `GHD-...` for draft items).
# The existing /projects kb-ui page reads them alongside hand-authored
# TASK-NNN / PROJECT-* files (Option A — single unified namespace).
#
# Requires GITHUB_PERSONAL_ACCESS_TOKEN to have `read:project` (fine-grained:
# "Projects: Read") on each org.
GITHUB_PROJECT_SYNC_ORGS=
# Sync interval in milliseconds. Default 15 minutes. Set to 0 to disable.
GITHUB_PROJECT_SYNC_INTERVAL_MS=900000
# Comma-separated case-insensitive substrings. Any project whose title
# contains one of these is skipped at sync time (and so are its items).
# Empty titles are always skipped. Default catches GitHub's auto-named
# "@<user>'s untitled project" boards plus categorization boards named
# "Breadchain Micro" / "Breadchain Macro". Set to "," to disable.
GITHUB_PROJECT_HIDE_TITLE_PATTERNS=untitled,micro,macro

# Service email account — IMAP poller checks this mailbox for whitelisted
# senders and routes them as inbound messages. Both must be set for the
# poller to start; otherwise it logs a warning and stays idle.
BREADBRICH_EMAIL=breadbrich@your-domain.example
BREADBRICH_EMAIL_PASSWORD=your-google-workspace-app-password

# Slack bot username — shown on the kb-ui /admin credentials table.
# Optional; falls back to "breadbrich" if unset.
SLACK_BOT_USERNAME=your-bot-username

# Google Calendar ID for the kb-ui calendar sync (iCal URL is built from this).
# Required for the calendar feature; sync returns an error if unset.
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Breadbrich's GitHub fine-grained PAT (his own account), authorized for the
# BreadchainCoop org with Contents/Issues/Pull requests RW + Actions/Metadata
# read. Enables the bundled github-mcp-server (mcp__github__*); auto-detected
# when present, server not loaded when absent. See rules/integrations/github.md.
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...
