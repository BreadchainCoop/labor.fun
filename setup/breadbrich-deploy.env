# Non-secret deployment configuration for the orchestrator + KB dashboard.
#
# This file is loaded by both systemd units via:
#   EnvironmentFile=-/opt/breadbrich/setup/breadbrich-deploy.env
# (The leading '-' tolerates a missing file — server code has its own
# defaults for everything here, so a missing file just falls back.)
#
# Secrets (DISCORD_BOT_TOKEN, CLAUDE_CODE_OAUTH_TOKEN,
# GITHUB_PERSONAL_ACCESS_TOKEN, DISCORD_DM_ALLOWED_ROLE_IDS,
# GITHUB_PROJECT_SYNC_ORGS, SHARED_KB_GROUP, …) live in
# /opt/breadbrich/.env (0600, breadbrich-owned, gitignored) and are
# loaded by readEnvFile inside the Node process. Do NOT put secrets here.

NODE_ENV=production

# Active org profile. Org-specific state (groups/, store/, data/) lives under
# /opt/breadbrich/profiles/$LABOR_PROFILE/. See src/profile.ts and
# docs/NEW-ORG-GUIDE.md. The deploy scripts read this to locate stateful paths.
LABOR_PROFILE=breadchain

# --- breadbrich.service (orchestrator) -----------------------------------

# Host address the agent containers reach the credential proxy on. Docker's
# default bridge gateway is 172.17.0.1 — change only if your host networking
# differs.
CREDENTIAL_PROXY_HOST=172.17.0.1

# --- breadbrich-kb.service (KB dashboard) --------------------------------

# Canonical group for the shared KB. The GitHub Projects V2 sync writes
# here (via SHARED_KB_GROUP read by config.ts), kb-ui reads here
# (CONTEXT_DIR), and the Discord-members sync writes people files here.
# Keep these two values aligned. CONTEXT_DIR points into the active profile.
SHARED_KB_GROUP=discord_main
CONTEXT_DIR=/opt/breadbrich/profiles/breadchain/groups/discord_main/context

KB_PORT=8080
USERS_FILE=/opt/breadbrich/kb-ui/users.json
DB_PATH=/opt/breadbrich/profiles/breadchain/store/messages.db
KB_ADMINS=admin
KB_SUPERADMINS=admin
